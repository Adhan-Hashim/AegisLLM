# AegisLLM Environment Configuration

# Database
POSTGRES_USER=aegis
POSTGRES_PASSWORD=password
POSTGRES_DB=aegisllm
DATABASE_URL=postgresql://aegis:password@postgres:5432/aegisllm

# Redis
REDIS_URL=redis://redis:6379/0

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_ENVIRONMENT=development

# Dashboard (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
